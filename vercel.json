{
  "version": 2,
  "buildCommand": "cd Frontend && npm install && npm run build && cd ..",
  "outputDirectory": "Frontend/dist",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
